{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "check": {
      "dependsOn": ["lint", "typecheck", "test:unit"]
    },
    "gen:types": {
      "dependsOn": ["^build"],
      "outputs": ["src/index.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
