NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/termsync_dev

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=<min-32-chars-random-secret>
JWT_REFRESH_SECRET=<min-32-chars-random-secret>
JWT_VERIFICATION_SECRET=<min-32-chars-random-secret>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>

GITHUB_CLIENT_ID=<github-oauth-client-id>
GITHUB_CLIENT_SECRET=<github-oauth-client-secret>

EMAIL_FROM=noreply@yourdomain.com
RESEND_API_KEY=<resend-api-key>
