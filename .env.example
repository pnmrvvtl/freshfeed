# TermSync Environment Variables
# Copy to .env and fill in values. App will crash on startup if required vars are missing.

# ─── App ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://termsync:termsync@localhost:5432/termsync_dev
TEST_DATABASE_URL=postgresql://termsync:termsync@localhost:5432/termsync_test

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ─── LLM ────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Email ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@termsync.app

# ─── Stripe ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAID_PRICE_ID=

# ─── CSRF ───────────────────────────────────────────────────────────────
CSRF_SECRET=change-me-to-random-32-char-string
